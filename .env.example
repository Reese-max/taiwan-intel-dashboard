# 複製成 .env 並填入實際值（.env 已被 .gitignore 排除，絕不進版控）。
# 雲端部署時改用 GitHub Actions Secrets 注入（見 .github/workflows/update-and-deploy.yml）。

# LLM（新聞正規化、AI 情勢摘要）— MiniMax
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=

# LLM fallback — NVIDIA
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=

# primary LLM 備援端點（可選；設了才啟用 — primary 失敗/空輸出時單次改走此端點）
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_MODEL=

# TWINKLE MCP（警政/採購/司法等政府開放資料查詢）
TWINKLE_MCP_URL=https://api.twinkleai.tw/mcp/
TWINKLE_MCP_TOKEN=

# 中央氣象署（地震/警特報）
CWA_API_KEY=

# 環境部資料開放平臺（AQI；需免費註冊取得 API Key）
MOENV_API_KEY=
