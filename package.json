{
  "name": "taiwan-intel-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && node scripts/build-network.mjs && node scripts/build-static.mjs",
    "build:static": "tsc --noEmit && node scripts/build-network.mjs && node scripts/build-static.mjs",
    "build:network": "node scripts/build-network.mjs",
    "fetch:police": "node --env-file=.env scripts/fetch-live.mjs --sources=police",
    "refresh": "node --env-file=.env scripts/fetch-live.mjs --sources=police,missing,twnews --exclusive",
    "refresh:news": "node --env-file=.env scripts/fetch-live.mjs --sources=twnews,missing",
    "refresh:ci:hourly": "node --env-file=.env scripts/fetch-live.mjs --sources=cwa,police,missing,twnews,rss,mofa,ncdr,mnd,cga,twcert,taipower,wra",
    "refresh:ci:daily": "node --env-file=.env scripts/fetch-live.mjs --sources=cwa,pcc,police,missing,twnews,rss,judicial,mofa,ncdr,mnd,cdc,tfda,cga,twcert,taipower,wra --exclusive",
    "validate:ci-mode": "npm test -- tests/ci-fetch-mode.test.ts tests/assert-pipeline-sources.test.ts && node scripts/validate-ci-mode.mjs",
    "audit:international-feeds": "node scripts/audit-international-feeds.mjs --min-ok-feeds=10 --min-raw-items=50",
    "audit:intl-risk": "node scripts/audit-intl-risk-distribution.mjs",
    "audit:domestic-risk": "node scripts/audit-domestic-risk-distribution.mjs",
    "audit:source-freshness": "node scripts/audit-source-freshness.mjs",
    "audit:coverage": "node scripts/audit-coverage.mjs",
    "audit:data-size": "node scripts/audit-data-size.mjs",
    "audit:source-provenance": "node scripts/audit-source-provenance.mjs",
    "audit:news-source-contribution": "node scripts/audit-news-source-contribution.mjs",
    "audit:network-quality": "node scripts/audit-network-quality.mjs",
    "migrate:source-provenance": "node scripts/migrate-source-provenance.mjs",
    "report:news-sources": "node scripts/report-news-source-contribution.mjs",
    "watch:daily-refresh": "scripts\\daily-refresh-loop.cmd",
    "watch:police-hourly": "scripts\\police-hourly-loop.cmd",
    "preview": "node scripts/police-control-server.mjs",
    "serve": "node --env-file=.env server/index.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.12",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
